<view class="expense-list-container">
  <view class="filter-bar {{!isLoggedIn ? 'disabled' : ''}}">
    <view class="filter-item {{filter === 'all' && isLoggedIn ? 'active' : ''}}" bindtap="onFilterChange" data-filter="all">全部</view>
    <view class="filter-item {{filter === 'today' && isLoggedIn ? 'active' : ''}}" bindtap="onFilterChange" data-filter="today">今日</view>
    <view class="filter-item {{filter === 'week' && isLoggedIn ? 'active' : ''}}" bindtap="onFilterChange" data-filter="week">本周</view>
    <view class="filter-item {{filter === 'month' && isLoggedIn ? 'active' : ''}}" bindtap="onFilterChange" data-filter="month">本月</view>
  </view>

  <view class="expense-list">
    <view wx:if="{{!isLoggedIn}}" class="login-tip">
      <view class="login-icon">🔒</view>
      <view class="login-tip-text">登录后查看收支明细</view>
      <view class="login-btn" bindtap="goToLogin">立即登录</view>
    </view>
    <block wx:elif="{{expenses.length > 0}}">
      <view class="expense-item" wx:for="{{expenses}}" wx:key="_id">
        <view class="expense-left">
          <view class="expense-category">{{item.category}}</view>
          <view class="expense-date">{{item.dateStr}}</view>
          <view class="expense-note" wx:if="{{item.note}}">{{item.note}}</view>
        </view>
        <view class="expense-right">
          <text class="expense-amount {{item.type === 'income' ? 'income' : ''}}">{{item.type === 'income' ? '+' : '-'}}¥{{item.amount}}</text>
          <text class="expense-member">{{item.type === 'income' ? '收入' : '支出'}}</text>
        </view>
      </view>
    </block>
    <view wx:elif="{{!loading}}" class="empty-tip">暂无收支记录</view>
  </view>
</view>
