.expense-list-container {
  background: #f5f5f5;
  min-height: 100vh;
}

.filter-bar {
  display: flex;
  background: #fff;
  padding: 20rpx;
  gap: 20rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
}

.filter-item.active {
  background: #667eea;
  color: #fff;
}

.filter-bar.disabled .filter-item {
  color: #ccc;
  background: #f0f0f0;
}

.expense-list {
  padding: 20rpx;
}

.expense-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.expense-left {
  flex: 1;
}

.expense-category {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.expense-date {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.expense-note {
  font-size: 24rpx;
  color: #666;
}

.expense-right {
  text-align: right;
}

.expense-amount {
  font-size: 36rpx;
  color: #ff4757;
  font-weight: bold;
  display: block;
}

.expense-amount.income {
  color: #2ed573;
}

.expense-category-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.type-badge {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.type-badge.expense {
  color: #ff4757;
  background: rgba(255, 71, 87, 0.1);
}

.type-badge.income {
  color: #2ed573;
  background: rgba(46, 213, 115, 0.1);
}

.empty-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 80rpx 0;
}

.login-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}

.login-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.login-tip-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 50rpx;
}

.login-btn {
  background: #667eea;
  color: #fff;
  font-size: 30rpx;
  padding: 24rpx 100rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}
