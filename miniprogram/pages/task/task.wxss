.task-container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.add-btn {
  background: #667eea;
  color: #fff;
  border-radius: 32rpx;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  line-height: 1;
}

.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.tab-item.active {
  background: #667eea;
  color: #fff;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.task-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.task-reward {
  font-size: 32rpx;
  color: #ff4757;
  font-weight: bold;
}

.task-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.task-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.task-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.task-status {
  font-size: 24rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  display: inline-block;
}

.task-status.pending {
  background: #e3f2fd;
  color: #1976d2;
}

.task-status.inProgress {
  background: #fff3e0;
  color: #f57c00;
}

.task-status.awaitConfirm {
  background: #fce4ec;
  color: #c2185b;
}

.task-status.completed {
  background: #e8f5e9;
  color: #388e3c;
}

.task-deadline {
  font-size: 24rpx;
  color: #999;
}

.action-btn {
  padding: 16rpx 40rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #fff;
  line-height: 1;
}

.action-btn.claim {
  background: #667eea;
}

.action-btn.complete {
  background: #ff9800;
}

.action-btn.confirm {
  background: #4caf50;
}

.action-btn.edit {
  background: #9e9e9e;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
}

.empty-tip text {
  color: #999;
  font-size: 28rpx;
}
