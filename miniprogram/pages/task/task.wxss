.task-container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.add-btn {
  background: #667eea;
  color: #fff;
  border-radius: 32rpx;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  line-height: 1;
}

.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.tab-item.active {
  background: #667eea;
  color: #fff;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-card-wrapper {
  position: relative;
  overflow: hidden;
  border-radius: 16rpx;
}

.task-card-main {
  position: relative;
  z-index: 2;
}

.task-delete {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 140rpx;
  background: #ff4757;
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
  border-radius: 0 16rpx 16rpx 0;
}

.task-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.task-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.task-reward {
  font-size: 32rpx;
  color: #ff4757;
  font-weight: bold;
}

.task-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.task-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.task-right {
  gap: 16rpx;
  flex-shrink: 0;
  margin-top: 15px;
}

.task-actions {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  align-items: center;
  justify-content: flex-end;
}

.task-status {
  font-size: 22rpx;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  display: inline-block;
  line-height: 1.2;
  white-space: nowrap;
}

.task-status.pending {
  background: #e3f2fd;
  color: #1976d2;
}

.task-status.inProgress {
  background: #fff3e0;
  color: #f57c00;
}

.task-status.awaitConfirm {
  background: #e8f5e9;
  color: #388e3c;
}

.task-status.completed {
  background: #e8f5e9;
  color: #388e3c;
}

.task-deadline {
  font-size: 24rpx;
  color: #999;
}

.action-btn {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #fff;
  line-height: 1;
  margin: 0;
}

.action-btn.claim {
  background: #667eea;
}

.action-btn.complete {
  background: #ff9800;
}

.action-btn.confirm {
  background: #4caf50;
}

.action-btn.edit {
  background: #9e9e9e;
}

.action-btn.view {
  background: #667eea;
}

.task-card.readonly {
  opacity: 0.95;
}

.empty-tip,
.loading-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.login-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}

.login-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.login-tip-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 50rpx;
}

.login-btn {
  background: #667eea;
  color: #fff;
  font-size: 30rpx;
  padding: 24rpx 100rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}
