<view class="task-container">
  <view class="header">
    <text class="title">任务中心</text>
    <button wx:if="{{isParent}}" class="add-btn" bindtap="goToAddTask">+ 发布任务</button>
  </view>

  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'all' ? 'active' : ''}}" bindtap="onTabChange" data-tab="all">全部</view>
    <view class="tab-item {{activeTab === 'pending' ? 'active' : ''}}" bindtap="onTabChange" data-tab="pending">待领取</view>
    <view class="tab-item {{activeTab === 'inProgress' ? 'active' : ''}}" bindtap="onTabChange" data-tab="inProgress">进行中</view>
    <view class="tab-item {{activeTab === 'awaitConfirm' ? 'active' : ''}}" bindtap="onTabChange" data-tab="awaitConfirm">待确认</view>
  </view>

  <view class="task-list">
    <view wx:if="{{!isLoggedIn}}" class="login-tip">
      <view class="login-icon">🔒</view>
      <view class="login-tip-text">登录后查看任务列表</view>
      <view class="login-btn" bindtap="goToLogin">立即登录</view>
    </view>
    <block wx:else>
      <view class="task-card-wrapper" wx:for="{{tasks}}" wx:key="_id">
        <view class="task-card-main"
              style="transform: translateX({{item.translateX || 0}}rpx); {{item.transition}}"
              bindtouchstart="handleTouchStart"
              bindtouchmove="handleTouchMove"
              bindtouchend="handleTouchEnd"
              data-index="{{index}}">
          <view class="task-card {{item.status !== 'pending' ? 'readonly' : ''}}" bindtap="goToTaskDetail" data-id="{{item._id}}" data-status="{{item.status}}">
            <view class="task-header">
              <text class="task-title">{{item.title}}</text>
              <text class="task-reward">+¥{{item.reward}}</text>
            </view>

            <view class="task-desc" wx:if="{{item.description}}">{{item.description}}</view>

            <view class="task-footer">
              <text class="task-deadline" wx:if="{{item.completedAt}}">截止: {{item.completedAt}}</text>
              <view class="task-right">
                <text class="task-status {{item.status}}">{{item.statusText}}</text>
                <view class="task-actions">
                  <button wx:if="{{item.status === 'pending'}}" class="action-btn claim" catchtap="claimTask" data-id="{{item._id}}">领取</button>
                  <button wx:if="{{item.status === 'inProgress'}}" class="action-btn complete" catchtap="completeTask" data-id="{{item._id}}">办结</button>
                  <button wx:if="{{item.status === 'pending' && isParent}}" class="action-btn edit" catchtap="goToEditTask" data-id="{{item._id}}">编辑</button>
                  <!-- <button wx:if="{{item.status !== 'pending'}}" class="action-btn view" catchtap="goToEditTask" data-id="{{item._id}}">查看</button> -->
                </view>
              </view>
            </view>
          </view>
        </view>
        <view wx:if="{{item.status === 'pending'}}" class="task-delete" catchtap="deleteTask" data-id="{{item._id}}">删除</view>
      </view>

      <view wx:if="{{tasks.length === 0}}" class="empty-tip">
        暂无任务
      </view>
    </block>
  </view>
</view>
