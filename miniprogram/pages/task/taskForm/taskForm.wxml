<view class="container">
  <view class="form-card">
    <!-- 操作人（只读） -->
    <view class="form-item">
      <text class="form-label">发布人</text>
      <view class="form-value readonly">
        <image class="creator-avatar" src="{{creator.avatarUrl}}" mode="aspectFill"/>
        <text class="creator-name">{{creator.nickName}}</text>
      </view>
    </view>

    <!-- 时间 -->
    <view class="form-item">
      <text class="form-label">截止时间</text>
      <view wx:if="{{readOnly}}" class="form-value readonly">{{dueDate || '-'}}</view>
      <picker wx:else mode="date" value="{{dueDate}}" bindchange="onDateChange">
        <view class="form-value picker">{{dueDate || '请选择截止日期'}}</view>
      </picker>
    </view>

    <!-- 任务名称 -->
    <view class="form-item">
      <text class="form-label">任务名称</text>
      <input
        class="form-input {{readOnly ? 'readonly' : ''}}"
        placeholder="请输入任务名称，如：整理房间"
        value="{{taskName}}"
        bindinput="onNameInput"
        disabled="{{readOnly}}"
      />
    </view>

    <!-- 任务详情 -->
    <view class="form-item">
      <text class="form-label">任务详情</text>
      <textarea
        class="form-textarea {{readOnly ? 'readonly' : ''}}"
        placeholder="请描述任务的具体要求和标准..."
        value="{{taskDesc}}"
        maxlength="200"
        bindinput="onDescInput"
        disabled="{{readOnly}}"
      />
      <text wx:if="{{!readOnly}}" class="char-count">{{taskDesc.length || 0}}/200</text>
    </view>

    <!-- 执行人 -->
    <view class="form-item">
      <text class="form-label">执行人</text>
      <view wx:if="{{readOnly}}" class="form-value readonly">
        <block wx:if="{{assignee}}">
          <image wx:if="{{assignee.avatarUrl}}" class="assignee-avatar" src="{{assignee.avatarUrl}}" mode="aspectFill"/>
          <text>{{assignee.nickName}}</text>
        </block>
        <text wx:else>-</text>
      </view>
      <picker wx:else bindchange="onAssigneeChange" value="{{assigneeIndex}}" range="{{familyMembers}}" range-key="nickName">
        <view class="form-value picker">
          <block wx:if="{{assignee}}">
            <image wx:if="{{assignee.avatarUrl}}" class="assignee-avatar" src="{{assignee.avatarUrl}}" mode="aspectFill"/>
            <text>{{assignee.nickName}}</text>
          </block>
          <text wx:else class="placeholder">请选择执行人</text>
        </view>
      </picker>
    </view>

    <!-- 任务奖励 -->
    <view class="form-item">
      <text class="form-label">任务奖励（元）</text>
      <input
        class="form-input {{readOnly ? 'readonly' : ''}}"
        type="digit"
        placeholder="0.00"
        value="{{reward}}"
        bindinput="onRewardInput"
        disabled="{{readOnly}}"
      />
    </view>

    <!-- 提交按钮 -->
    <button wx:if="{{!readOnly}}" class="submit-btn {{canSubmit ? '' : 'disabled'}}" bindtap="submitTask" disabled="{{!canSubmit}}">
      {{isEdit ? '保存修改' : '发布任务'}}
    </button>
  </view>
</view>
