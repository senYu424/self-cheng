.expense-container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 类型切换标签 */
.type-tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
}

.tab-item.active.expense {
  background: #ff4757;
  color: #fff;
}

.tab-item.active.income {
  background: #2ed573;
  color: #fff;
}

/* 金额区域 */
.amount-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
}

.amount-section .label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 20rpx;
}

.amount-input {
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #e0e0e0;
  padding-bottom: 20rpx;
}

.currency {
  font-size: 48rpx;
  color: #333;
  margin-right: 20rpx;
  font-weight: bold;
}

.amount-section.income .currency {
  color: #2ed573;
}

.amount-section.expense .currency {
  color: #ff4757;
}

.amount-input input {
  flex: 1;
  font-size: 64rpx;
  color: #333;
}

/* 表单区域 */
.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item .label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  padding: 16rpx 32rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666;
}

.category-item.active.expense {
  background: #ff4757;
  color: #fff;
  border-color: #ff4757;
}

.category-item.active.income {
  background: #2ed573;
  color: #fff;
  border-color: #2ed573;
}

.picker {
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.form-item input {
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

radio-group label {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

/* 保存按钮 */
.submit-btn {
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 40rpx;
  color: #fff;
}

.submit-btn.expense {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
}

.submit-btn.income {
  background: linear-gradient(135deg, #2ed573 0%, #26af62 100%);
}
