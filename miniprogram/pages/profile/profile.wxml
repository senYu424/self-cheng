<view class="profile-container">
  <view class="user-card">
    <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
    <view class="user-info">
      <text class="nickname">{{userInfo.nickname}}</text>
      <text class="role">{{userInfo.role === 'parent' ? '家长' : '孩子'}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">家庭成员</view>
    <view class="member-list">
      <view class="member-item" wx:for="{{familyMembers}}" wx:key="_id">
        <image class="member-avatar" src="{{item.avatarUrl}}" />
        <view class="member-info">
          <text class="member-name">{{item.nickname}}</text>
          <text class="member-role">{{item.role === 'parent' ? '家长' : '孩子'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">设置</view>
    <view class="setting-list">
      <view class="setting-item" bindtap="goToCategoryManage">
        <text>分类管理</text>
        <text class="arrow">></text>
      </view>
      <view class="setting-item" bindtap="goToAbout">
        <text>关于我们</text>
        <text class="arrow">></text>
      </view>
    </view>
  </view>

  <button class="logout-btn" bindtap="logout">退出登录</button>
</view>
