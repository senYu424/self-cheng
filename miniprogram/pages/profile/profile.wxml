<view class="profile-container">
  <!-- 已登录：用户信息卡片 -->
  <view class="user-card" wx:if="{{isLoggedIn}}">
    <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
    <view class="user-info">
      <text class="nickname">{{userInfo.nickname}}</text>
      <text class="role">{{userInfo.role === 'parent' ? '家长' : '孩子'}}</text>
    </view>
  </view>

  <!-- 未登录：登录提示卡片 -->
  <view class="login-card" wx:else>
    <view class="login-icon">👤</view>
    <view class="login-text">您还未登录</view>
    <view class="login-desc">登录后可查看个人信息和家庭成员</view>
    <view class="login-btn" bindtap="goToLogin">立即登录</view>
  </view>

  <!-- 家庭成员（仅登录显示） -->
  <view class="section" wx:if="{{isLoggedIn}}">
    <view class="section-title">家庭成员</view>
    <view class="member-list">
      <view class="member-item" wx:for="{{familyMembers}}" wx:key="_id">
        <image class="member-avatar" src="{{item.avatarUrl}}" />
        <view class="member-info">
          <text class="member-name">{{item.nickname}}</text>
          <text class="member-role">{{item.role === 'parent' ? '家长' : '孩子'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 设置（始终显示） -->
  <view class="section">
    <view class="section-title">设置</view>
    <view class="setting-list">
      <view class="setting-item" bindtap="goToCategoryManage">
        <text>分类管理</text>
        <text class="arrow">></text>
      </view>
      <view class="setting-item" bindtap="goToAbout">
        <text>关于我们</text>
        <text class="arrow">></text>
      </view>
    </view>
  </view>

  <!-- 退出登录（仅登录显示） -->
  <button class="logout-btn" wx:if="{{isLoggedIn}}" bindtap="logout">退出登录</button>
</view>
