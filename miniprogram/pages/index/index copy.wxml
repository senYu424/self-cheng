<view class="container">
  <!-- 未登录状态：显示登录入口 -->
  <view wx:if="{{!isLoggedIn}}" class="login-section">
    <view class="login-card" bindtap="getWeChatInfo">
      <view class="avatar-placeholder">?</view>
      <!-- <text class="login-text">点击获取微信头像和昵称</text> -->
        <button 
      class="get-user-btn" 
      open-type="chooseAvatar" 
      bind:chooseavatar="onChooseAvatar"
    >
      <image 
        wx:if="{{tempAvatarUrl}}" 
        class="avatar" 
        src="{{tempAvatarUrl}}" 
        mode="aspectFill"
      />
      <!-- <view wx:else class="avatar-placeholder">
        <text class="login-text">点击获取头像</text>
      </view> -->
       <text class="login-text" wx:else>点击获取微信头像和昵称</text>
    </button>
     <input 
      type="nickname" 
      class="nickname-input" 
      placeholder="请输入昵称"
      value="{{tempNickName}}"
      bind:input="onNicknameInput"
      bind:blur="onNicknameChange"
    />
    </view>
  </view>

  <!-- 已登录状态：显示首页内容 -->
  <view wx:if="{{isLoggedIn}}" class="home-content">
    <!-- 用户信息卡片 -->
    <view class="user-card">
      <!-- <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" /> -->
        <image 
        wx:if="{{tempAvatarUrl}}" 
        class="user-avatar"
        src="{{tempAvatarUrl}}" 
        mode="aspectFill"
      />
      <view class="user-info">
        <text class="user-name">{{userInfo.nickName}}</text>
        <text class="user-date">{{currentDate}}</text>
      </view>
    </view>

    <!-- 支出概览 -->
    <view class="stats-section">
      <view class="stat-card today">
        <text class="stat-label">今日支出</text>
        <text class="stat-amount">¥{{todayExpense}}</text>
      </view>
      <view class="stat-card month">
        <text class="stat-label">本月支出</text>
        <text class="stat-amount">¥{{monthExpense}}</text>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="quick-actions">
      <view class="action-btn primary" bindtap="goToExpense">
        <text class="btn-icon">+</text>
        <text class="btn-text">记一笔</text>
      </view>
      <view class="action-btn" bindtap="goToExpenseList">
        <text class="btn-icon">📋</text>
        <text class="btn-text">明细</text>
      </view>
      <view class="action-btn" bindtap="goToSaving">
        <text class="btn-icon">🏦</text>
        <text class="btn-text">存钱</text>
      </view>
      <view class="action-btn" bindtap="goToTask">
        <text class="btn-icon">✅</text>
        <text class="btn-text">任务</text>
      </view>
    </view>

    <!-- 最近支出 -->
    <view class="recent-section" wx:if="{{recentExpenses.length > 0}}">
      <view class="section-header">
        <text class="section-title">最近支出</text>
        <text class="section-more" bindtap="goToExpenseList">查看更多 ></text>
      </view>
      <view class="expense-list">
        <view class="expense-item" wx:for="{{recentExpenses}}" wx:key="index">
          <view class="expense-info">
            <text class="expense-category">{{item.category}}</text>
            <text class="expense-time">{{item.time}}</text>
          </view>
          <text class="expense-amount">-¥{{item.amount}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
