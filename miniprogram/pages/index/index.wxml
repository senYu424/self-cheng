<view class="container">
  <view class="home-content">
    <!-- 用户信息卡片 -->
    <view class="user-card">
      <image
        class="user-avatar"
        src="{{isLoggedIn ? userInfo.avatarUrl : 'https://mmbiz.qpic.cn/mmbiz/icTdbqWNOwNRna42FI242Lcia07jQodd2FJGIYQfG0LAJGFxM4FbnQP6yfMxBgJ0F3YRqJCJ1aPAK2dQagdusBZg/0'}}"
        mode="aspectFill"
      />
      <view class="user-info">
        <text class="user-name">{{isLoggedIn ? userInfo.nickName : '游客'}}</text>
        <text class="user-phone" wx:if="{{isLoggedIn && userInfo.phone}}">{{userInfo.phone}}</text>
        <text class="user-date">{{currentDate}}</text>
      </view>
    </view>

    <!-- 收支概览 -->
    <view class="stats-section">
      <view class="stat-card expense">
        <text class="stat-label">今日支出</text>
        <text class="stat-amount expense">¥{{todayExpense}}</text>
      </view>
      <view class="stat-card income">
        <text class="stat-label">今日收入</text>
        <text class="stat-amount income">¥{{todayIncome}}</text>
      </view>
      <view class="stat-card expense">
        <text class="stat-label">本月支出</text>
        <text class="stat-amount expense">¥{{monthExpense}}</text>
      </view>
      <view class="stat-card income">
        <text class="stat-label">本月收入</text>
        <text class="stat-amount income">¥{{monthIncome}}</text>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="quick-actions">
      <view class="action-btn primary" bindtap="goToExpense">
        <text class="btn-icon">+</text>
        <text class="btn-text">记一笔</text>
      </view>
      <view class="action-btn" bindtap="goToExpenseList">
        <text class="btn-icon">📋</text>
        <text class="btn-text">明细</text>
      </view>
      <view class="action-btn" bindtap="goToSaving">
        <text class="btn-icon">🏦</text>
        <text class="btn-text">存钱</text>
      </view>
      <view class="action-btn" bindtap="goToTask">
        <text class="btn-icon">✅</text>
        <text class="btn-text">任务</text>
      </view>
    </view>

    <!-- 最近收支 -->
    <view class="recent-section" wx:if="{{recentExpenses.length > 0}}">
      <view class="section-header">
        <text class="section-title">最近收支</text>
        <text class="section-more" bindtap="goToExpenseList">查看更多 ></text>
      </view>
      <view class="expense-list">
        <view class="expense-item" wx:for="{{recentExpenses}}" wx:key="index">
          <view class="expense-info">
            <view class="expense-category-wrap">
              <text class="expense-category">{{item.category}}</text>
              <view class="type-badge {{item.recordType === 'income' ? 'income' : 'expense'}}">{{item.recordType === 'income' ? '收入' : '支出'}}</view>
            </view>
            <text class="expense-time">{{item.time}}</text>
          </view>
          <text class="expense-amount {{item.recordType === 'income' ? 'income' : ''}}">{{item.recordType === 'income' ? '+' : '-'}}¥{{item.amount}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
